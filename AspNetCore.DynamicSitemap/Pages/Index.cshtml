@page
@model IndexModel
@{
    ViewData["Title"] = "Dynamic Sitemap Generator Demo";
}

<div class="text-center">
    <h1 class="display-4">ASP.NET Core Dynamic Sitemap Generator</h1>
    <p>
        Production-ready multilingual sitemap solution built with .NET 8.
    </p>

    <hr />

    <p><strong>Available Endpoints:</strong></p>

    <p>
        <a href="/sitemap.xml">/sitemap.xml</a><br />
        <a href="/sitemap-en.xml">/sitemap-en.xml</a><br />
        <a href="/sitemap-hi.xml">/sitemap-hi.xml</a><br />
        <a href="/sitemap-index.xml">/sitemap-index.xml</a>
    </p>

    <hr />

    <p>
        Built using <strong>AstroHoraZ.SeoToolkit.DynamicSitemap</strong>
    </p>
</div>
